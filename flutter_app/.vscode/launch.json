      "program": "lib/main.dart"
    },
    {
      "name": "Digital Ecclesia (Web)",
      "request": "launch",
      "type": "dart",
      "flutterMode": "debug",
      "program": "lib/main.dart",
      "args": ["-d", "chrome", "--web-port", "8080"]
    }
  ]
}
